{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 500,
  "height": 300,
  "title": {
    "text": "Australia vs Top Global Tourism Destinations",
    "subtitle": "International visitor arrivals, millions (2024)",
    "fontSize": 16,
    "subtitleFontSize": 12
  },
  "data": {
    "url": "data/australia_vs_world.csv"
  },
  "layer": [
    {
      "mark": {
        "type": "rule",
        "strokeWidth": 2
      },
      "encoding": {
        "y": {
          "field": "country",
          "type": "nominal",
          "sort": "-x",
          "axis": {"title": null, "labelFontSize": 11}
        },
        "x": {
          "field": "visitors_millions",
          "type": "quantitative",
          "axis": {"title": "International Arrivals (millions)", "grid": false}
        },
        "x2": {"value": 0},
        "color": {
          "condition": {
            "test": "datum.highlight === 'yes'",
            "value": "#c1440e"
          },
          "value": "#003049"
        }
      }
    },
    {
      "mark": {
        "type": "point",
        "filled": true,
        "size": 100
      },
      "encoding": {
        "y": {
          "field": "country",
          "type": "nominal",
          "sort": "-x"
        },
        "x": {
          "field": "visitors_millions",
          "type": "quantitative"
        },
        "color": {
          "condition": {
            "test": "datum.highlight === 'yes'",
            "value": "#c1440e"
          },
          "value": "#003049"
        },
        "tooltip": [
          {"field": "country", "type": "nominal", "title": "Country"},
          {"field": "visitors_millions", "type": "quantitative", "title": "Arrivals (millions)"}
        ]
      }
    }
  ]
}